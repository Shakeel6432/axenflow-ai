generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String          @unique
  emailVerified   DateTime?
  password        String?
  image           String?
  company         String?
  country         String?
  notifyProduct   Boolean         @default(true) @map("notify_product")
  notifyMarketing Boolean         @default(false) @map("notify_marketing")
  role            UserRole        @default(USER)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  accounts        Account[]
  sessions        Session[]
  searchHistory   SearchHistory[]
  downloads       Download[]
  savedLeads      SavedLead[]
  exportHistory   ExportHistory[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Country {
  id     String  @id @default(cuid())
  name   String  @unique
  code   String  @unique
  states State[]

  @@map("countries")
}

model State {
  id        String   @id @default(cuid())
  countryId String   @map("country_id")
  name      String
  slug      String
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  cities    City[]

  @@unique([countryId, slug])
  @@index([slug])
  @@map("states")
}

model City {
  id      String @id @default(cuid())
  stateId String @map("state_id")
  name    String
  slug    String
  state   State  @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([stateId, slug])
  @@index([slug])
  @@index([name])
  @@map("cities")
}

model Category {
  id         String     @id @default(cuid())
  name       String     @unique
  slug       String     @unique
  businesses Business[]

  @@index([slug])
  @@map("categories")
}

enum BusinessStatus {
  PENDING
  APPROVED
  REJECTED
}

model Business {
  id            String         @id @default(cuid())
  slug          String         @unique
  businessName  String         @map("business_name")
  owner         String?
  categoryId    String?        @map("category_id")
  categoryName  String         @map("category")
  website       String?
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String?
  country       String?
  postalCode    String?        @map("postal_code")
  latitude      Float?
  longitude     Float?
  rating        Float?
  reviewsCount  Int            @default(0) @map("reviews_count")
  googleMapsUrl String?        @map("google_maps_url")
  source        String?        @default("manual")
  status        BusinessStatus @default(APPROVED)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  category      Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  savedBy       SavedLead[]

  @@index([businessName])
  @@index([categoryName])
  @@index([city])
  @@index([state])
  @@index([country])
  @@index([phone])
  @@index([website])
  @@index([rating])
  @@index([reviewsCount])
  @@index([createdAt])
  @@index([status])
  @@index([city, categoryName])
  @@index([state, categoryName])
  @@map("businesses")
}

model SearchHistory {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  keyword      String?
  city         String?
  category     String?
  totalResults Int      @default(0) @map("total_results")
  searchedAt   DateTime @default(now()) @map("searched_at")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([searchedAt])
  @@index([userId])
  @@map("search_history")
}

/** Desktop tool download tracking (website accounts only). */
model Download {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  toolName  String   @map("tool_name")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolName])
  @@index([createdAt])
  @@map("downloads")
}

/** User-bookmarked businesses from Lead Finder. */
model SavedLead {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  businessId String   @map("business_id")
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId, createdAt])
  @@index([businessId])
  @@map("saved_leads")
}

enum ExportFormat {
  CSV
  XLSX
  JSON
}

/** Audit log of lead exports (file built client-side; metadata stored here). */
model ExportHistory {
  id          String       @id @default(cuid())
  userId      String       @map("user_id")
  format      ExportFormat
  rowCount    Int          @map("row_count")
  source      String       @default("search")
  filtersJson String?      @map("filters_json") @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([format])
  @@map("export_history")
}
